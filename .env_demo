# Rename to .env

# ── Model ────────────────────────────────────────────────
WHISPER_MODEL=medium

# ── Audio ────────────────────────────────────────────────
SAMPLE_RATE=16000

# ── VAD ──────────────────────────────────────────────────
SILENCE_THRESH=0.040
SILENCE_SEC=1.0
MIN_SPEECH_SEC=0.4

# ── Whisper ───────────────────────────────────────────────
BEAM_SIZE=5
CONTEXT_WINDOW=4

# ── Language ─────────────────────────────────────────────
LANGUAGE=vi

# ── Ollama (polish.py) ────────────────────────────────────
OLLAMA_MODEL=gemma3:4b # llama3.2:3b
OLLAMA_URL=http://localhost:11434
OLLAMA_TIMEOUT=60
OLLAMA_BOOT_SEC=15
